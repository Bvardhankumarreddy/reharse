# Better Auth — generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# App URL (used by Better Auth for cookies/redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL — same DB as the NestJS API
DATABASE_URL=postgresql://rehearse:rehearse@localhost:5432/rehearse

# NestJS API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
